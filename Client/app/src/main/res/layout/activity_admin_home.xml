<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TIÊU ĐỀ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Dashboard"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="18dp" />

        <!-- MÔ TẢ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn chức năng để quản lý"
            android:textSize="14sp"
            android:textColor="#444444"
            android:layout_marginBottom="22dp" />

        <!-- CARD STYLE DÙNG CHUNG -->
        <!-- QUẢN LÝ NGƯỜI DÙNG -->
        <LinearLayout
            android:id="@+id/btnUserManager"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="14dp"
            android:background="@drawable/item_card_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Quản lý người dùng"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- GỬI THÔNG BÁO -->
        <LinearLayout
            android:id="@+id/btnSendNotification"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="14dp"
            android:background="@drawable/item_card_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Gửi thông báo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- QUẢN LÝ TRẬN ĐẤU -->
        <LinearLayout
            android:id="@+id/btnMatchManager"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="14dp"
            android:background="@drawable/item_card_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Quản lý trận đấu"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- QUẢN LÝ GIÁ VÉ -->
        <LinearLayout
            android:id="@+id/btnTicketManager"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="14dp"
            android:background="@drawable/item_card_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Quản lý giá vé"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- DUYỆT VÉ -->
        <LinearLayout
            android:id="@+id/btnApproveTicket"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="14dp"
            android:background="@drawable/item_card_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Duyệt vé"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- QUẢN LÝ XẾP HẠNG -->
        <LinearLayout
            android:id="@+id/btnRanking"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="22dp"
            android:background="@drawable/item_card_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Quản lý xếp hạng"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ĐĂNG XUẤT -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đăng xuất"
            android:textAllCaps="false"
            android:background="@drawable/btn_bg"
            android:textColor="#FFFFFF"
            android:padding="15dp" />

    </LinearLayout>
</ScrollView>
