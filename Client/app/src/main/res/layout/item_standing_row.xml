<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tvTeam"
        android:text="1. Hà Nội FC"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="5"
        android:textSize="13sp"/>

    <TextView android:id="@+id/tvP"   android:text="10" android:gravity="center"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
    <TextView android:id="@+id/tvW"   android:text="7" android:gravity="center"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
    <TextView android:id="@+id/tvD"   android:text="3" android:gravity="center"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
    <TextView android:id="@+id/tvL"   android:text="0" android:gravity="center"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
    <TextView android:id="@+id/tvGD"  android:text="+12" android:gravity="center"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2"/>
    <TextView android:id="@+id/tvPTS" android:text="24" android:textStyle="bold" android:gravity="center"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.4"/>
</LinearLayout>
